# .clangd — Language server configuration for the TLS source tree.
#
# The TLS sources are compiled exclusively inside a Linux Docker container
# (Ubuntu 24.04) against a custom-built OpenSSL 3.3.2 at /opt/openssl.
# On a Windows development host those headers are absent; clangd would emit
# cascading "unknown type / undeclared identifier" false-positive errors.
#
# On Windows: ~21 IDE-only false-positive errors remain (struct timespec,
#   nanosleep, NULL, AF_UNSPEC, etc.).  These are benign — they occur because
#   clangd with --target=x86_64-pc-linux-gnu cannot find the Linux sysroot
#   headers (<time.h>, <sys/socket.h>, <stdio.h>, etc.) on Windows, and the
#   ${workspaceFolder} variable in -I flags is not always expanded when
#   resolving nested include subdirectories (openssl/ssl.h vs msquic.h).
#   The actual Docker build on the Linux server compiles cleanly — all POSIX
#   types are available there.  These errors do NOT indicate a real problem.
#
# On Linux / inside Docker: clangd finds the real headers at the paths set
#   by -I flags and all diagnostics work normally.
#
# NOTE: The ide_stubs/ directory is excluded from all diagnostics via the
#   first --- section below.  The openssl/ssl.h stub and posix_types.h stubs
#   ARE referenced in the -I flag but their resolution depends on
#   ${workspaceFolder} expansion which is not guaranteed in all clangd
#   versions.  They serve as reference documentation for the types used.

---
# ── Suppress all diagnostics for the IDE stubs (they are not compiled) ─────
If:
  PathMatch: ".*[\\/]ide_stubs[\\/].*"

Diagnostics:
  Suppress: "*"

---
# ── TLS production source files ──────────────────────────────────────────────
If:
  PathMatch: ".*[\\/]src[\\/]tls[\\/][^/\\\\]+\\.(c|h)$"

CompileFlags:
  Add:
    # Target triple: treat these files as Linux code even on a Windows host.
    - --target=x86_64-pc-linux-gnu

    # _GNU_SOURCE enables all POSIX/GNU extensions:
    #   - struct timespec, clock_gettime(), CLOCK_MONOTONIC  (POSIX.1b)
    #   - nanosleep()                                        (POSIX.1b)
    #   - SO_REUSEPORT                                       (Linux socket)
    #   - getaddrinfo(), freeaddrinfo()                      (POSIX.1-2001)
    #
    # NOTE: We use _GNU_SOURCE (not _POSIX_C_SOURCE=200809L) because
    # _POSIX_C_SOURCE=200809L sets __USE_XOPEN2K8 in glibc, which makes
    # usleep() invisible (POSIX.1-2008 deprecated it and glibc hides it
    # under that condition).  _GNU_SOURCE avoids that restriction.
    - -D_GNU_SOURCE
    - -D_POSIX_C_SOURCE=200809L

    # Use c11 here (not gnu11) for clangd compatibility.
    # struct timespec was moved into the C11 standard, so it is available
    # without feature-test macros under -std=c11.  The actual Docker build
    # uses -std=gnu11 (CMAKE_C_EXTENSIONS ON in CMakeLists.txt); this
    # setting is only for IDE navigation and does not affect compilation.
    - -std=c11

    # ── Include search order ────────────────────────────────────────────────
    #
    # 1. ide_stubs/ (project-local, Windows host fallback)
    #    Contains openssl/ssl.h, openssl/err.h, openssl/provider.h stubs
    #    with just enough type definitions for clangd to parse the source.
    #    On Linux the real header at /opt/openssl/include is found first
    #    (listed at priority 2 below), so the stub is never used there.
    - -I${workspaceFolder}/src/tls/ide_stubs

    # 2. Real OpenSSL 3.3.2 headers — present inside Docker / on a Linux host
    #    with the custom OpenSSL build.  Not present on Windows; the Suppress
    #    block below prevents cascading errors when these are absent.
    - -I/opt/openssl/include

    # liboqs headers (reference only; TLS sources use OQS exclusively via
    # the OpenSSL provider API and do not include liboqs headers directly).
    - -I/opt/oqs/include

    # Do not stop after the first batch of errors; show all diagnostics.
    - -ferror-limit=0

  # Strip Windows-specific compiler flags that the MSVC-targeting host
  # toolchain or CMake may inject.
  Remove:
    - -fms-extensions
    - -fms-compatibility
    - /W*
    - /wd*
    - /MT
    - /MD
    - /GR*
    - /EH*

Diagnostics:
  # Suppress "file not found" for ALL headers absent on the Windows host
  # (/opt/openssl/include/openssl/ssl.h, Linux sysroot time.h, etc.).
  # When every header fails consistently and every failure is suppressed,
  # clangd enters a clean "no-types" state and shows 0 errors.
  Suppress:
    - pp_file_not_found
    - pp_include_next_absolute_path

  ClangTidy:
    Add:
      - clang-analyzer-*
      - bugprone-*
      - performance-*
      - cert-*
    Remove:
      # OpenSSL headers use reserved identifiers and deprecated-style macros
      # (SSL_OP_BIT, SSL_set_tlsext_host_name, etc.) that trigger these
      # checks on code we cannot modify.
      - bugprone-reserved-identifier
      - bugprone-macro-parentheses
      # cert-err33-c fires on every SSL_* call that returns int; the TLS
      # sources already check every return value explicitly.
      - cert-err33-c

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true
